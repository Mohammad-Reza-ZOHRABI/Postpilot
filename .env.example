# =============================================================================
# Mail-Server — Environment variables
# Copy to .env and adjust for your deployment.
# =============================================================================

# ── Mode ──────────────────────────────────────────────────────────────────────
# catch   → Mailpit only, nothing sent (safe default for development)
# relay   → Postfix relays via external SMTP (requires POSTFIX_RELAY_HOST)
# direct  → Postfix sends directly to MX servers (requires PTR + DKIM + SPF)
MAIL_MODE=catch

# ── Postfix identity ─────────────────────────────────────────────────────────
POSTFIX_HOSTNAME=mail.example.com
POSTFIX_MYORIGIN=example.com

# ── Postfix limits ────────────────────────────────────────────────────────────
POSTFIX_MESSAGE_SIZE=52428800       # Max message size in bytes (default: 50 MB)
POSTFIX_MYNETWORKS=127.0.0.0/8     # Allowed sender networks (loopback only)

# ── Relay mode (MAIL_MODE=relay) ──────────────────────────────────────────────
POSTFIX_RELAY_HOST=[smtp.sendgrid.net]:587
POSTFIX_RELAY_USER=apikey
# POSTFIX_RELAY_PASS=yourpassword   ← prefer Docker secret: smtp_relay_password

# ── DKIM signing ──────────────────────────────────────────────────────────────
DKIM_ENABLED=false
DKIM_DOMAIN=example.com             # Defaults to POSTFIX_MYORIGIN if empty
DKIM_SELECTOR=default
DKIM_KEY_SIZE=2048                   # Key size for auto-generation (2048 or 4096)
# DKIM_PRIVATE_KEY_B64=...           ← base64-encoded PEM; prefer Docker secret

# ── TLS for Postfix submission ────────────────────────────────────────────────
TLS_ENABLED=false
# TLS certs via Docker secrets: tls_cert + tls_key (base64-encoded PEM)

# ── Mailpit ───────────────────────────────────────────────────────────────────
MP_SMTP_PORT=1025                    # SMTP listen port (apps connect here)
MP_UI_PORT=8025                      # Web UI port
MP_MAX_MESSAGES=500                  # Max stored messages (oldest auto-deleted)
# MP_UI_AUTH=user:$2y$...            ← bcrypt hash; prefer Docker secret: mailpit_auth

# ── Traefik integration (docker-compose.traefik.yml) ─────────────────────────
MAILPIT_DOMAIN=mail.example.com      # Domain for Mailpit web UI
# TRAEFIK_AUTH_USERS=admin:$$2y$$... ← htpasswd bcrypt with $$ escaping
# TRAEFIK_NETWORK=traefik_network    ← External Traefik network name
# TRAEFIK_ENTRYPOINT=websecure       ← Traefik HTTPS entrypoint
# TRAEFIK_CERTRESOLVER=letsencrypt   ← Traefik certificate resolver

# ── Container resources ──────────────────────────────────────────────────────
# MAILSERVER_IMAGE=rezozohrabi/postpilot:latest
# MAILSERVER_CONTAINER_NAME=mailserver
# MAILSERVER_MEMORY_LIMIT=128M
# MAILSERVER_CPU_LIMIT=0.25
